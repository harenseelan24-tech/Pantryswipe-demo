# Copy this file to .env for local development.
# NEVER commit .env — it is listed in .gitignore.
# In production, inject these via your cloud provider's secrets manager
# (AWS SSM Parameter Store, GCP Secret Manager, Doppler, etc.).

# ── Database ────────────────────────────────────────────────────────────────────
# Required. Postgres connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/pantryswipe

# ── Server ──────────────────────────────────────────────────────────────────────
# Port the Express server binds to. Defaults to 8080 if not set.
PORT=8080

# Controls log level and pino-pretty formatting.
# Values: development | test | production
NODE_ENV=development

# ── AI (Anthropic) ──────────────────────────────────────────────────────────────
# Required for /api/recipes/ai-chef and /api/vision endpoints.
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── External APIs ───────────────────────────────────────────────────────────────
# Used by the barcode lookup route as a fallback after the local DB.
# Optional — barcode route degrades gracefully if unset.
# UPCITEMDB_API_KEY=...

# ── Rate limiting (optional overrides) ──────────────────────────────────────────
# Uncomment to override the defaults set in src/middleware/rateLimiters.ts.
# RATE_LIMIT_WINDOW_MS=900000   # 15 min window
# RATE_LIMIT_MAX=300            # requests per window (global)
