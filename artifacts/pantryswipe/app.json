{
  "expo": {
    "name": "PantrySwipe",
    "slug": "pantryswipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pantryswipe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141210"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pantryswipe.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PantrySwipe uses your camera to scan barcodes and automatically add food items to your pantry."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#141210"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "PantrySwipe uses your camera to scan barcodes and automatically add food items to your pantry."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
