# PantrySwipe — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ─── API Server URL ────────────────────────────────────────────────────────────
# Set this to your Replit preview URL so the Expo app can reach the API server.
# Find it: open the Replit Webview tab → copy the base URL (no trailing path).
# Example: https://pantryswipe.yourusername.repl.co
#
# After changing this value you MUST restart Metro (stop and re-run the app)
# because EXPO_PUBLIC_ vars are baked in at bundle time, not read at runtime.
EXPO_PUBLIC_API_DOMAIN=YOUR-REPLIT-SLUG.replit.app

# ─── inference.sh API key (optional) ──────────────────────────────────────────
# Enables the real AI Chef (inference.sh → claude-sonnet).
# Get a key at https://inference.sh — leave blank to use the API server fallback.
EXPO_PUBLIC_INFSH_API_KEY=
